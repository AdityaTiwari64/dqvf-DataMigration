{
  "name": "dqvf",
  "version": "1.0.0",
  "description": "Data Quality Validation Framework — Supervisor Agent architecture for database migration validation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:full": "tsx src/index.ts --config configs/example.yml --instruction \"Run full validation on all tables\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/pdfkit": "^0.17.6",
    "dotenv": "^17.4.2",
    "fastest-levenshtein": "^1.0.16",
    "js-yaml": "^4.1.0",
    "knex": "^3.1.0",
    "mongodb": "^7.2.0",
    "openai": "^4.80.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "simple-statistics": "^7.8.7",
    "tedious": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
