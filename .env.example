# ─── Database Connections ───────────────────────────────────────────
# Source database (MongoDB)
SOURCE_DB_TYPE=mongodb
SOURCE_DB_URI=mongodb://localhost:27017/source_db
SOURCE_DB_HOST=localhost
SOURCE_DB_PORT=27017
SOURCE_DB_USER=
SOURCE_DB_PASSWORD=
SOURCE_DB_NAME=source_db

# Target database (Neon/PostgreSQL)
TARGET_DB_CONNECTION_STRING=postgresql://user:password@host.neon.tech/target_db?sslmode=require
TARGET_DB_HOST=host.neon.tech
TARGET_DB_PORT=5432
TARGET_DB_USER=user
TARGET_DB_PASSWORD=your_password
TARGET_DB_NAME=target_db
TARGET_DB_SCHEMA=public
TARGET_DB_SSL=true

# ─── LLM API Keys ──────────────────────────────────────────────────
# Only one is required; set based on your llm.provider config
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
LLM_PROVIDER=openrouter
LLM_API_KEY=your_openai_compatible_key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# ─── Slack Notifications ───────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Report Output ─────────────────────────────────────────────────
REPORT_OUTPUT_DIR=./reports
